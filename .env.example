# Image build settings
BASE_IMAGE=docker.1ms.run/library/ubuntu:24.04
ZSDK_VERSION=1.0.1
SDK_TOOLCHAINS=arm-zephyr-eabi
HOSTTYPE=x86_64
IMAGE_NAME=zephyr-docker-sdk

# Project workspace settings for docker-compose.example.yml
ZEPHYR_WORKSPACE=/path/to/zephyr-workspace
ZEPHYR_BASE=/workspace/zephyr-workspace/zephyr
SYNC_ZEPHYR_REQUIREMENTS=1
CONTAINER_NAME=zephyr-sdk-dev
